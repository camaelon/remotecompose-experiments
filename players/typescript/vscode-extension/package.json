{
  "name": "rc-viewer",
  "displayName": "RemoteCompose Viewer",
  "description": "Preview RemoteCompose .rc and .rcd binary files",
  "version": "0.1.0",
  "publisher": "remote-compose",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "rc.preview",
        "displayName": "RemoteCompose Preview",
        "selector": [
          {
            "filenamePattern": "*.rc"
          },
          {
            "filenamePattern": "*.rcd"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "build": "bash build.sh"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}
